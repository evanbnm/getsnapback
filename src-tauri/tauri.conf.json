{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Snapback",
  "version": "0.2.0",
  "identifier": "app.snapback.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Snapback",
        "width": 780,
        "height": 560,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/exiftool", "binaries/ffmpeg"]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
